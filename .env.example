# =============================================================================
# HuggingFace
# =============================================================================
# Create a token at https://huggingface.co/settings/tokens (read access is enough)
HF_TOKEN=hf_your_token_here

# Local directory to cache downloaded model weights.
# Mounted into the container so weights persist across restarts.
HF_CACHE=~/.cache/huggingface

# =============================================================================
# Model
# =============================================================================
# HuggingFace model ID for an nvfp4 model, e.g.:
#   nvidia/Llama-3.1-Nemotron-Ultra-253B-v1-FP4
#   nvidia/Llama-3.3-70B-Instruct-FP4
MODEL=nvidia/Gemma-4-31B-IT-NVFP4

# Optional: override the model name exposed in the API
# (useful if your clients hard-code a model name like "default")
# MODEL_ALIAS=

# =============================================================================
# Server
# =============================================================================
HOST=0.0.0.0
PORT=8000

# =============================================================================
# GPU
# =============================================================================
# Number of GPUs for tensor parallelism (set to your GPU count)
TENSOR_PARALLEL=1

# Fraction of GPU VRAM to reserve for vLLM (leave a little headroom)
GPU_MEM_UTIL=0.92

# =============================================================================
# Context & memory
# =============================================================================
# Maximum context length in tokens.
# 262144 = 256K. Reduce if you run out of VRAM — long contexts are expensive.
# Tip: 128K (131072) is a good starting point for a single H100/A100.
MAX_MODEL_LEN=131072

# KV cache precision. fp8 cuts KV memory roughly in half vs fp16 with
# negligible quality loss — strongly recommended.
KV_CACHE_DTYPE=fp8

# =============================================================================
# Concurrency
# =============================================================================
# Maximum number of sequences processed simultaneously.
# vLLM uses continuous batching, so this is a soft cap on in-flight requests.
MAX_NUM_SEQS=256

# Enable prefix caching — reuses KV cache for identical prompt prefixes.
# Essential for agentic workflows where the system prompt is sent every turn.
ENABLE_PREFIX_CACHING=true
